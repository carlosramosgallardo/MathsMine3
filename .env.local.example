# ================================================================
# MathsMine3 — Environment Variables
# Copy this file to .env.local and fill in the values.
# NEVER commit .env.local to version control.
# ================================================================

# ── Supabase (required) ─────────────────────────────────────────
# Find these in your Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── WalletConnect / Web3Modal (required for crypto wallets) ─────
# Create a project at https://cloud.walletconnect.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your-walletconnect-project-id

# ── Google OAuth (optional — enables G·Play sign-in) ────────────
# 1. Create a project at https://console.cloud.google.com
# 2. Enable People API
# 3. Create an OAuth 2.0 Client ID (Web application type)
# 4. Add your domain (e.g. https://mathsmine3.xyz) to Authorized Origins
# Only the "openid" scope is used — no email, name, or profile data is accessed.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# ── Gameplay (optional) ─────────────────────────────────────────
# Base mining reward per answer (default: 0.00001)
NEXT_PUBLIC_FAKE_MINING_PRICE=0.00001

# ── Analytics (optional) ────────────────────────────────────────
# Google Analytics 4 Measurement ID (format: G-XXXXXXXXXX)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Donations (optional) ────────────────────────────────────────
# Ethereum wallet address shown in the donation section
NEXT_PUBLIC_ADMIN_WALLET=0xYourEthereumAddressHere
